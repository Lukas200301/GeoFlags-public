{
  "name": "geoflags-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\" --names \"backend,frontend\" --prefix-colors \"green,cyan\"",
    "dev:backend": "cd backend && npm run dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview --port 3000 --host 0.0.0.0",
    "preview:all": "concurrently \"npm run dev:backend\" \"npm run preview\" --names \"backend,frontend\" --prefix-colors \"green,cyan\"",
    "postinstall": "nuxt prepare && node scripts/fix-world-countries.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nuxt/icon": "^1.7.4",
    "@vueuse/core": "^11.3.0",
    "@vueuse/motion": "^3.0.3",
    "@vueuse/nuxt": "^11.3.0",
    "chart.js": "^4.5.1",
    "globe.gl": "^2.45.0",
    "maplibre-gl": "^5.10.0",
    "nuxt": "^3.15.0",
    "prisma": "^6.18.0",
    "socket.io-client": "^4.8.1",
    "three": "^0.181.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/eslint": "^0.7.4",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.2.0"
  }
}
